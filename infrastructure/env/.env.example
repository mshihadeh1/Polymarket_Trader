POSTGRES_DB=polymarket_trader
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/polymarket_trader
REDIS_URL=redis://redis:6379/0
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
APP_ENV=development
LOG_LEVEL=INFO
USE_MOCK_POLYMARKET=true
USE_MOCK_POLYMARKET_CLIENT=true
LIVE_EXECUTION_ENABLED=false
MAX_MARKET_EXPOSURE_USD=500
FEATURE_TRADE_WINDOWS=5,15,30
DEFAULT_UNDERLYINGS=BTC,ETH
ENABLE_DB_PERSISTENCE=false
SQLITE_FALLBACK_PATH=data/polymarket_trader.db
EXTERNAL_HISTORICAL_PROVIDER=binance
USE_MOCK_EXTERNAL_PROVIDER=true
BINANCE_BASE_URL=https://api.binance.com
POLYMARKET_API_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
EXTERNAL_PROVIDER_SYMBOL_MAP={"BTC":"BTCUSDT","ETH":"ETHUSDT"}
