# Mirror of the root `.env.example` for reference.
# Docker Compose now reads `../.env`, so copy the root example to `.env` for normal use.

POSTGRES_DB=polymarket_trader
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/polymarket_trader
REDIS_URL=redis://redis:6379/0
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
APP_ENV=development
LOG_LEVEL=INFO

# Polymarket mode switches:
USE_MOCK_POLYMARKET=true
USE_MOCK_POLYMARKET_CLIENT=true

LIVE_EXECUTION_ENABLED=false
MAX_MARKET_EXPOSURE_USD=500
FEATURE_TRADE_WINDOWS=5,15,30
DEFAULT_UNDERLYINGS=BTC,ETH
ENABLE_DB_PERSISTENCE=false
SQLITE_FALLBACK_PATH=data/polymarket_trader.db

# Historical provider selection:
EXTERNAL_HISTORICAL_PROVIDER=binance
USE_MOCK_EXTERNAL_PROVIDER=true
BINANCE_BASE_URL=https://api.binance.com

# Local CSV datasets for 1-minute bar backtests:
# Leave CSV_ETH_PATH empty unless you have an ETH dataset locally.
CSV_BTC_PATH=data/datasets/BTCUSD-1m-104wks-data.csv
CSV_ETH_PATH=
CSV_SOL_PATH=data/datasets/SOLUSD-1m-104wks-data.csv
CSV_PROVIDER_PATHS={"BTC":"data/datasets/BTCUSD-1m-104wks-data.csv","SOL":"data/datasets/SOLUSD-1m-104wks-data.csv"}

# Real Polymarket endpoints:
POLYMARKET_API_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Recent Hyperliquid enrichment:
HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info
USE_MOCK_HYPERLIQUID_RECENT=true
HYPERLIQUID_RECENT_TRADE_LIMIT=500
HYPERLIQUID_RECENT_LOOKBACK_MINUTES=240

# Symbol mapping for external providers:
EXTERNAL_PROVIDER_SYMBOL_MAP={"BTC":"BTCUSDT","ETH":"ETHUSDT","SOL":"SOLUSDT"}

# Backtest costs:
BACKTEST_FEE_BPS=7
BACKTEST_SLIPPAGE_BPS=5
BACKTEST_POSITION_SIZE=100

# Live paper loop controls:
# Keep PAPER_TRADING_LOOP_ENABLED=false for the current validation, backtest, and observation runbooks.
PAPER_TRADING_LOOP_ENABLED=false
PAPER_TRADING_LOOP_SECONDS=30
PAPER_TRADING_UNDERLYINGS=BTC
PAPER_TRADING_MARKET_TYPES=crypto_5m,crypto_15m
PAPER_TRADING_STRATEGY=combined_cvd_gap
