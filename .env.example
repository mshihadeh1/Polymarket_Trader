# Copy this file to `.env` before running Docker Compose or local dev commands.
# Fastest path: keep the defaults below for mock mode, then start the stack.

POSTGRES_DB=polymarket_trader
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/polymarket_trader
REDIS_URL=redis://redis:6379/0
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
APP_ENV=development
LOG_LEVEL=INFO

# Polymarket mode switches:
# USE_MOCK_POLYMARKET keeps the app in mock-first mode for seeded development.
# USE_MOCK_POLYMARKET_CLIENT controls whether the real Polymarket REST/WS adapter is used.
USE_MOCK_POLYMARKET=true
USE_MOCK_POLYMARKET_CLIENT=true

LIVE_EXECUTION_ENABLED=false
MAX_MARKET_EXPOSURE_USD=500
FEATURE_TRADE_WINDOWS=5,15,30
DEFAULT_UNDERLYINGS=BTC,ETH
ENABLE_DB_PERSISTENCE=false
SQLITE_FALLBACK_PATH=data/polymarket_trader.db

# External historical provider for research/backtests.
# Options today: binance, csv, tardis (placeholder), parquet (placeholder).
EXTERNAL_HISTORICAL_PROVIDER=binance
USE_MOCK_EXTERNAL_PROVIDER=true
BINANCE_BASE_URL=https://api.binance.com

# Local 1-minute dataset paths for CSV historical mode.
# Expected columns: ts/open/high/low/close/volume.
CSV_PROVIDER_PATHS={"BTC":"data/datasets/BTCUSD-1m-104wks-data.csv","ETH":"data/datasets/eth_1m.csv","SOL":"data/datasets/SOLUSD-1m-104wks-data.csv"}

# Real Polymarket observation mode endpoints.
POLYMARKET_API_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Internal symbol to provider symbol mapping for historical data adapters.
EXTERNAL_PROVIDER_SYMBOL_MAP={"BTC":"BTCUSDT","ETH":"ETHUSDT","SOL":"SOLUSDT"}

# Backtest cost assumptions for sequential 1-minute replay.
BACKTEST_FEE_BPS=7
BACKTEST_SLIPPAGE_BPS=5
BACKTEST_POSITION_SIZE=100

# Continuous live paper loop controls.
PAPER_TRADING_LOOP_ENABLED=false
PAPER_TRADING_LOOP_SECONDS=30
PAPER_TRADING_UNDERLYINGS=BTC
PAPER_TRADING_MARKET_TYPES=crypto_5m,crypto_15m
PAPER_TRADING_STRATEGY=combined_cvd_gap
